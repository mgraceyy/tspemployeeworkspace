# Example Prometheus scrape config for TalaSora Prime DTR.
# Point Prometheus at the app container (internal network) — never expose /metrics publicly.
#
# Usage:
#   export METRICS_TOKEN=your-scrape-token
#   envsubst < docs/prometheus.yml.example > /etc/prometheus/prometheus.yml

global:
  scrape_interval: 30s
  evaluation_interval: 30s

rule_files:
  - alerts.yml

scrape_configs:
  - job_name: dtr
    metrics_path: /metrics
    scheme: http
    bearer_token: ${METRICS_TOKEN}
    static_configs:
      - targets: ["app:8080"]
        labels:
          service: dtr