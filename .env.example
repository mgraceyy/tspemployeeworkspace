DATABASE_URL=postgres://dtr:dtr@localhost:5432/dtr

# Required: at least 64 random characters. Never use the example value in production.
SESSION_SECRET=change-me-to-a-random-string-at-least-64-characters-long-for-signed-cookies-ok

# Dev only: creates ADMIN / 1234 when no employees exist. Set false (or unset) in production.
SEED_DEFAULT_ADMIN=true

# CI/E2E only: creates E2E001 / 482915 when missing. Never enable in production.
# SEED_E2E_FIXTURES=true

# Optional: require Bearer token or ?token= query param to scrape /metrics.
# METRICS_TOKEN=
RUST_LOG=dtr=debug,tower_http=info,sqlx=warn

# Set LOG_FORMAT=json for structured JSON logs (production log aggregation).
# LOG_FORMAT=json

# Set APP_ENV=production or SESSION_SECURE_COOKIES=true behind HTTPS
APP_ENV=development
SESSION_SECURE_COOKIES=false

# Trust X-Forwarded-For / X-Real-IP from your reverse proxy (rate limiting + logging).
# Only enable when ALL client traffic passes through a proxy that OVERWRITES these headers
# (see docs/nginx.conf.example — use $remote_addr, not $proxy_add_x_forwarded_for).
TRUST_PROXY_HEADERS=false

# Store login/POST rate limits in PostgreSQL (required when running multiple app replicas).
SHARED_RATE_LIMITS=false

# Server bind address and port (default 0.0.0.0:8080).
BIND_ADDR=0.0.0.0
PORT=8080

# PostgreSQL connection pool size per app process (default 5). Lower per replica when scaling out.
DATABASE_MAX_CONNECTIONS=5

# Requirement file uploads (PDF, images, Word — max 10 MB by default)
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760