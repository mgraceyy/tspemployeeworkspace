# Production Compose — copy to .env before: docker compose -f docker-compose.prod.yml up -d

POSTGRES_USER=dtr
POSTGRES_PASSWORD=change-me-strong-db-password

# Required: 64+ random characters. Never commit the real value.
SESSION_SECRET=change-me-to-a-random-string-at-least-64-characters-long-for-signed-cookies-ok

# Trust proxy headers only when ALL traffic reaches the app through caddy/nginx (default in prod compose).
TRUST_PROXY_HEADERS=false

# Persist login/POST rate limits in PostgreSQL when scaling app replicas beyond one instance.
SHARED_RATE_LIMITS=true

SEED_DEFAULT_ADMIN=false
PORT=8080
DATABASE_MAX_CONNECTIONS=5
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_BYTES=10485760

BACKUP_RETENTION_DAYS=14
# Optional: webhook URL for backup failure alerts (Slack/Discord incoming webhook).
# BACKUP_WEBHOOK_URL=
RUST_LOG=dtr=info,tower_http=warn,sqlx=warn

# Required in production: protect /metrics from public scraping (Bearer token or ?token= query param).
METRICS_TOKEN=change-me-to-a-long-random-metrics-scrape-token